---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import StarCTA from '../../components/StarCTA.astro';
import SiteFooter from '../../components/SiteFooter.astro';
---

<BaseLayout
	title="scs-vibe"
	description="Give Claude Code the context it needs to work with your project. Set up in 15 minutes with a single slash command."
>
	<Nav />
	<div class="plugin-page">
		<div class="plugin-hero">
			<p class="hero-eyebrow">For Solo Developers</p>
			<h1>scs-vibe</h1>
			<p>
				Stop Claude from coding you into corners. In 15 minutes, scs-vibe gives Claude enough
				context to work <strong>with</strong> your system instead of against it.
			</p>
			<div class="hero-ctas">
				<a
					href="https://github.com/tim-mccrimmon/structured-context-spec/tree/main/plugins/scs-vibe"
					class="btn btn-primary"
					target="_blank"
					rel="noopener"
				>
					Get scs-vibe on GitHub
				</a>
				<a href="/docs/plugins/scs-vibe" class="btn btn-secondary">Read the docs</a>
			</div>
		</div>

		<!-- Demo video -->
		<section class="section" style="padding: 0 0 3rem;">
			<div class="video-embed" style="max-width: 760px; border-radius: 8px; overflow: hidden;">
				<iframe
					src="https://www.youtube.com/embed/boO86wbPoqI"
					title="SCS Vibe Demo"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
					allowfullscreen
				></iframe>
			</div>
		</section>

		<hr class="section-divider" />

		<!-- How it works -->
		<section class="section" style="padding-left: 0; padding-right: 0;">
			<h2>How it works</h2>
			<p style="color: var(--color-text-muted); max-width: 60ch;">
				Point scs-vibe at a PRD or an existing project directory. It scans what's there, asks a
				few targeted questions, and generates structured context Claude uses every session.
			</p>

			<div class="install-block">
				<p>Install via Claude Code</p>
				<code>/scs-vibe:init</code>
			</div>

			<p style="color: var(--color-text-muted); font-size: 0.9rem; margin-top: 0.5rem;">
				Run this slash command from within Claude Code. Follow the prompts.
			</p>
		</section>

		<hr class="section-divider" />

		<!-- What it outputs -->
		<section class="section" style="padding-left: 0; padding-right: 0;">
			<h2>What it generates</h2>
			<p style="color: var(--color-text-muted); max-width: 60ch; margin-bottom: 1.5rem;">
				scs-vibe writes two things to your project:
			</p>
			<div class="card-grid">
				<div class="card">
					<h3><code>CLAUDE.md</code></h3>
					<p>
						The primary context file Claude Code reads at the start of every session. Contains
						your project's architecture, conventions, and constraints in structured format.
					</p>
				</div>
				<div class="card">
					<h3><code>.claude/rules/</code></h3>
					<p>
						Modular rule files that extend <code>CLAUDE.md</code>. Organized by concern:
						architecture, security, patterns, and more.
					</p>
				</div>
			</div>
			<p style="color: var(--color-text-muted); font-size: 0.9rem; margin-top: 1.5rem;">
				Both files are plain text and live in your repo — version them like any other code.
			</p>
		</section>

		<hr class="section-divider" />

		<section class="section" style="padding-left: 0; padding-right: 0;">
			<StarCTA />
		</section>

		<div class="section" style="padding-left: 0; padding-right: 0; padding-top: 0;">
			<p>
				<a href="/docs/plugins/scs-vibe">Full documentation &rarr;</a>
				&nbsp;&middot;&nbsp;
				<a href="/plugins/scs-team">Looking for the team plugin? &rarr;</a>
			</p>
		</div>
	</div>
	<SiteFooter />
</BaseLayout>
