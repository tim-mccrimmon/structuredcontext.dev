---
const currentPath = Astro.url.pathname;

function isActive(path: string) {
	if (path === '/') return currentPath === '/';
	return currentPath.startsWith(path);
}
---

<nav class="site-nav">
	<div class="nav-inner">
		<a href="/" class="nav-logo" aria-label="Structured Context home">
			<img src="/favicon.svg" alt="" width="28" height="28" />
			<span>Structured Context</span>
		</a>
		<ul class="nav-links">
			<li><a href="/blog" class:list={['nav-link', { active: isActive('/blog') }]}>Blog</a></li>
			<li><a href="/docs" class:list={['nav-link', { active: isActive('/docs') }]}>Docs</a></li>
			<li><a href="/plugins/scs-vibe" class:list={['nav-link', { active: isActive('/plugins') }]}>Plugins</a></li>
			<li>
				<a
					href="https://github.com/tim-mccrimmon/structured-context-spec"
					class="nav-link nav-github"
					target="_blank"
					rel="noopener"
				>
					GitHub ★
				</a>
			</li>
		</ul>
	</div>
</nav>
