---
interface Props {
	variant?: 'inline' | 'block';
}
const { variant = 'block' } = Astro.props;
---

<div class:list={['star-cta', `star-cta--${variant}`]}>
	<p>
		If SCS is solving a real problem for you,
		<a
			href="https://github.com/tim-mccrimmon/structured-context-spec"
			target="_blank"
			rel="noopener"
		>star the repo</a>
		— it helps other developers find it.
	</p>
</div>
