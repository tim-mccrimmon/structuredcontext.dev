---
---

<div class="substack-embed">
	<p class="substack-heading">Stay in the loop</p>
	<p class="substack-label">New articles when they publish. No noise.</p>
	<form
		action="https://tmccrimm.substack.com/api/v1/free?nojs=true"
		method="post"
		class="substack-form"
	>
		<input
			type="email"
			name="email"
			placeholder="your@email.com"
			required
			class="substack-input"
		/>
		<button type="submit" class="substack-btn">Subscribe</button>
	</form>
	<p class="substack-footer">
		Powered by <a href="https://tmccrimm.substack.com" target="_blank" rel="noopener">Substack</a>
	</p>
</div>

<style>
.substack-embed {
	border: 1px solid var(--color-border);
	border-radius: 8px;
	padding: 1.25rem;
}

.substack-heading {
	font-size: 0.95rem;
	font-weight: 600;
	margin: 0 0 0.25rem;
}

.substack-label {
	font-size: 0.85rem;
	color: var(--color-text-muted);
	margin: 0 0 1rem;
}

.substack-form {
	display: flex;
	flex-direction: column;
	gap: 0.5rem;
}

.substack-input {
	width: 100%;
	padding: 0.55rem 0.75rem;
	border: 1px solid var(--color-border);
	border-radius: 6px;
	font-size: 0.9rem;
	font-family: inherit;
	background: #fff;
}

.substack-input:focus {
	outline: none;
	border-color: var(--color-accent);
}

.substack-btn {
	padding: 0.55rem 1rem;
	background: var(--color-accent);
	color: #fff;
	border: none;
	border-radius: 6px;
	font-size: 0.9rem;
	font-weight: 600;
	font-family: inherit;
	cursor: pointer;
}

.substack-btn:hover {
	background: var(--color-accent-hover);
}

.substack-footer {
	font-size: 0.75rem;
	color: var(--color-text-muted);
	margin: 0.75rem 0 0;
}

.substack-footer a {
	color: var(--color-text-muted);
}
</style>
