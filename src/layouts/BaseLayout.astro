---
import '../styles/site.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
}

const {
	title,
	description = 'Context Engineering for AI development. A structured, versioned approach to AI context management.',
	ogImage = 'https://structuredcontext.dev/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>{title} — Structured Context</title>
	<meta name="description" content={description} />
	<link rel="canonical" href={canonicalURL} />

	<meta property="og:title" content={`${title} — Structured Context`} />
	<meta property="og:description" content={description} />
	<meta property="og:image" content={ogImage} />
	<meta property="og:url" content={canonicalURL} />
	<meta property="og:type" content="website" />
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content={`${title} — Structured Context`} />
	<meta name="twitter:description" content={description} />
	<meta name="twitter:image" content={ogImage} />

	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

	<script defer data-domain="structuredcontext.dev" src="https://plausible.io/js/script.outbound-links.js"></script>
</head>
<body>
	<slot />
</body>
</html>
